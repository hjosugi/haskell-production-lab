executable hps-tui-kanban
  import: shared
  main-is: Main.hs
  hs-source-dirs: app/tui-kanban
  build-depends: haskell-production-lab

test-suite hps-test
  import: shared
  type: exitcode-stdio-1.0
  main-is: Main.hs
  hs-source-dirs: test
  build-depends: haskell-production-lab
