{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "humblr-database",
  "main": "workers/database.mjs",
  "compatibility_date": "2026-07-08",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "humblr-db",
      "database_id": "replace-with-cloudflare-d1-id"
    }
  ]
}
