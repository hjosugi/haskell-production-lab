{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "humblr-storage",
  "main": "workers/storage.mjs",
  "compatibility_date": "2026-07-10",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "logs": { "enabled": true, "head_sampling_rate": 1 }
  },
  "r2_buckets": [
    {
      "binding": "BUCKET",
      "bucket_name": "humblr-assets"
    }
  ]
}
